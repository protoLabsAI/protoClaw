{
  "agents": {
    "defaults": {
      "workspace": "/sandbox",
      "model": "auto",
      "provider": "vllm",
      "maxTokens": 4096,
      "contextWindowTokens": 262144,
      "temperature": 0.3,
      "maxToolIterations": 20,
      "reasoningEffort": null
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": true
  },
  "providers": {
    "vllm": {
      "apiKey": "none",
      "apiBase": "http://protolabs-1:8000/v1",
      "extraHeaders": null
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": false,
      "intervalS": 1800
    }
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "provider": "duckduckgo",
        "apiKey": "",
        "baseUrl": "",
        "maxResults": 5
      }
    },
    "exec": {
      "timeout": 60,
      "pathAppend": ""
    },
    "restrictToWorkspace": true,
    "mcpServers": {
      "protolabs": {
        "url": "http://host.docker.internal:18791/mcp"
      }
    }
  }
}
